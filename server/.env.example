# Comma-separated emails that can upload content (admins)
ADMIN_EMAILS=you@example.com,editor@example.com

# Change in production (min 32 characters)
JWT_SECRET=change-me-to-a-long-random-string-in-production

PORT=8080

# Set to true to disable login/admin requirements locally (never use in production)
DEV_BYPASS_AUTH=false

# Supabase (https://supabase.com/dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Optional: service role key for server-side admin (never expose in the browser)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
